{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-workflow-playbook.local/schemas/task.schema.json",
  "title": "AI Workflow Playbook Task",
  "type": "object",
  "required": [
    "schema_version",
    "task_id",
    "title",
    "owner",
    "phase",
    "type_tags",
    "objective",
    "acceptance_criteria"
  ],
  "oneOf": [
    {
      "required": [
        "verify"
      ]
    },
    {
      "required": [
        "test"
      ]
    }
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "playbook.task.v1"
    },
    "task_id": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9._-]*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "phase": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string"
    },
    "type_tags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "type": "string",
            "minLength": 1
          },
          {
            "type": "object",
            "required": [
              "id",
              "description"
            ],
            "additionalProperties": false,
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "description": {
                "type": "string",
                "minLength": 1
              },
              "test": {
                "type": "string",
                "minLength": 1
              },
              "verify": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        ]
      }
    },
    "test": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "verify": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "files": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "context_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "heavy_mode": {
      "type": "string",
      "enum": [
        "none",
        "optional",
        "required"
      ],
      "default": "none"
    },
    "runtime_verification": {
      "type": "string",
      "enum": [
        "not_required",
        "conditional",
        "required"
      ],
      "default": "conditional"
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ],
      "default": "medium"
    },
    "public_tests_required": {
      "type": "string",
      "enum": [
        "not_required",
        "conditional",
        "required"
      ],
      "default": "conditional"
    },
    "critic_required": {
      "type": "string",
      "enum": [
        "not_required",
        "conditional",
        "required"
      ],
      "default": "conditional"
    },
    "holdout_required": {
      "type": "string",
      "enum": [
        "not_required",
        "conditional",
        "required"
      ],
      "default": "conditional"
    },
    "mutation_required": {
      "type": "string",
      "enum": [
        "not_required",
        "conditional",
        "required"
      ],
      "default": "conditional"
    },
    "property_required": {
      "type": "string",
      "enum": [
        "not_required",
        "conditional",
        "required"
      ],
      "default": "conditional"
    },
    "visual_contract": {
      "type": "string",
      "enum": [
        "not_applicable",
        "optional",
        "required"
      ],
      "default": "optional"
    },
    "correction_budget": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10
    },
    "cost_budget": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "object"
        }
      ]
    }
  }
}
