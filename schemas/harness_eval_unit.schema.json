{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-workflow-playbook.local/schemas/harness_eval_unit.schema.json",
  "title": "HarnessEvalUnit",
  "type": "object",
  "required": [
    "schema_version",
    "unit_id",
    "task_id",
    "condition",
    "trial_index",
    "model",
    "harness_version",
    "adapter_version",
    "prompt_version",
    "prompt_hash",
    "tool_registry_version",
    "memory_policy_version",
    "permission_policy_version",
    "environment",
    "dataset_version",
    "scorer_version",
    "budget",
    "timeout_seconds",
    "retry_policy",
    "delivery_profile",
    "compatibility_fingerprint"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "const": "playbook.harness_eval_unit.v1" },
    "unit_id": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "condition": { "type": "string", "minLength": 1 },
    "trial_index": { "type": "integer", "minimum": 0 },
    "model": { "type": "object" },
    "harness_version": { "type": "string", "minLength": 1 },
    "adapter_version": { "type": "string", "minLength": 1 },
    "prompt_version": { "type": "string", "minLength": 1 },
    "prompt_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "tool_registry_version": { "type": "string", "minLength": 1 },
    "memory_policy_version": { "type": "string", "minLength": 1 },
    "permission_policy_version": { "type": "string", "minLength": 1 },
    "environment": { "type": "object" },
    "dataset_version": { "type": "string", "minLength": 1 },
    "scorer_version": { "type": "string", "minLength": 1 },
    "budget": { "type": "object" },
    "timeout_seconds": { "type": ["number", "string", "null"] },
    "retry_policy": { "type": "string", "minLength": 1 },
    "delivery_profile": { "type": "string", "minLength": 1 },
    "compatibility_fingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}
