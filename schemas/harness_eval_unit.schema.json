{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-workflow-playbook.local/schemas/harness_eval_unit.schema.json",
  "title": "HarnessEvalUnit",
  "$comment": "Draft planning contract. The MVP companion suite does not yet emit HarnessEvalUnit artifacts; do not treat this schema as an enforced runtime contract until a producer is added.",
  "type": "object",
  "required": [
    "schema_version",
    "unit_id",
    "task_id",
    "model",
    "harness_version",
    "prompt_version",
    "tool_registry_version",
    "memory_policy_version",
    "permission_policy_version",
    "environment",
    "dataset_version",
    "scorer_version",
    "budget"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "const": "playbook.harness_eval_unit.v1" },
    "unit_id": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "model": { "type": "object" },
    "harness_version": { "type": "string", "minLength": 1 },
    "prompt_version": { "type": "string", "minLength": 1 },
    "tool_registry_version": { "type": "string", "minLength": 1 },
    "memory_policy_version": { "type": "string", "minLength": 1 },
    "permission_policy_version": { "type": "string", "minLength": 1 },
    "environment": { "type": "object" },
    "dataset_version": { "type": "string", "minLength": 1 },
    "scorer_version": { "type": "string", "minLength": 1 },
    "budget": { "type": "object" }
  }
}
